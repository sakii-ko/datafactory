# non-committed cumbersome / local-only scripts and experiments
scratch/

# python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# data farm outputs (never commit generated datasets)
out/
runs/
datasets/
*.mp4
*.png
*.jpg
*.exr
!docs/**/*.png

# UE build/intermediate
ue/**/Binaries/
ue/**/Intermediate/
ue/**/Saved/
ue/**/DerivedDataCache/
# imported third-party assets (large, regenerable, license-mixed — never commit)
ue/**/Content/Imported/

# env / secrets
.env
*.local

# downloaded character assets (Mixamo = account-licensed; CC-BY = attribution) — registry holds the URLs, not the binaries
assets_in/

# UE imported character/scene content (licensed/large/regenerable from the FBX + import) + build artifacts
ue/DataFarmCapture/Content/DataFarm/
ue/DataFarmCapture/Intermediate/
ue/DataFarmCapture/Saved/
ue/DataFarmCapture/DerivedDataCache/
ue/DataFarmCapture/Binaries/
ue/DataFarmCapture/Plugins/*/Binaries/
ue/DataFarmCapture/Plugins/*/Intermediate/
